{
  "expo": {
    "name": "DokTap",
    "slug": "DokTap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "projectId": "0ab5ba42-7ef9-49a9-9532-8ffb128da8f2",

    "plugins": [
      "expo-dev-client",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0097B2"
        }
      ]
    ],

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to find nearby hospitals.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location to find nearby hospitals."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyBvHDOYPDHhgPIq3apqehtGGorUtE3Ui6Y"
      }
    },

    "android": {
      "package": "com.anonymous.ReactNative",

      "googleServicesFile": "./android/app/google-services.json",

      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },

      "edgeToEdgeEnabled": true,

      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ],

      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBvHDOYPDHhgPIq3apqehtGGorUtE3Ui6Y"
        }
      }
    },

    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
